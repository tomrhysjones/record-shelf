# Copy this file to `.env` for local development.
# .env is gitignored — never commit secrets.

# Django
SECRET_KEY=change-me-to-something-long-and-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — local Postgres example.
# Render/Railway/Fly will provide their own DATABASE_URL automatically.
DATABASE_URL=postgres://recordshelf:recordshelf@localhost:5432/recordshelf
